# API Authentication
QPULSE_API_KEY=your-api-key-here

# Rate Limiting (optional)
RATE_LIMIT=20/minute
GLOBAL_RATE_LIMIT=100/minute

# Concurrency Limits (optional)
MAX_CONCURRENT_PER_IP=2
MAX_CONCURRENT_GLOBAL=10

# Base URL for report links (optional, default: https://qrep-api.tigzig.com)
BASE_URL=https://your-domain.com

# Additional CORS origins (optional, comma-separated)
CORS_EXTRA_ORIGINS=https://your-frontend.com

# Cleanup endpoint key (optional, defaults to QPULSE_API_KEY)
CLEANUP_API_KEY=your-cleanup-key-here
